# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
*/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
*/coverage/

# next.js
.next/
frontend/.next/
out/
frontend/out/

# production builds
build/
dist/
backend/dist/
frontend/build/

# misc
.DS_Store
*.pem
Thumbs.db

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# environment files
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# allow example env files
!.env.example
!backend/.env.example
!frontend/.env.example

# vercel
.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts

# backend runtime storage
backend/storage/
backend/uploads/
storage/
uploads/

# local database/files
*.sqlite
*.sqlite3
*.db

# OS/editor
.vscode/
.idea/